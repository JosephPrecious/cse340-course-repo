<%- include('partials/header') %>

<main class="container">

    <section class="page-header">
        <h1><%= title %></h1>
    </section>

    <% if (errors && errors.length > 0) { %>

        <div class="error-container">

            <% errors.forEach(error => { %>

                <p><%= error.msg %></p>

            <% }) %>

        </div>

    <% } %>

    <form
        action="/edit-organization/<%= organization.organization_id %>"
        method="POST"
        class="form-card"
    >

        <div class="form-group">

            <label for="name">
                Organization Name
            </label>

            <input
                type="text"
                id="name"
                name="name"
                value="<%= organization.name %>"
                required
                maxlength="150"
            >

        </div>

        <div class="form-group">

            <label for="description">
                Description
            </label>

            <textarea
                id="description"
                name="description"
                required
                maxlength="500"
            ><%= organization.description %></textarea>

        </div>

        <div class="form-group">

            <label for="contactEmail">
                Contact Email
            </label>

            <input
                type="email"
                id="contactEmail"
                name="contactEmail"
                value="<%= organization.contact_email %>"
                required
            >

        </div>

        <div class="form-group">

            <label for="logoFilename">
                Logo Filename
            </label>

            <input
                type="text"
                id="logoFilename"
                name="logoFilename"
                value="<%= organization.logo_filename %>"
                required
            >

        </div>

        <button
            type="submit"
            class="btn-primary"
        >
            Update Organization
        </button>

    </form>

</main>

<%- include('partials/footer') %>