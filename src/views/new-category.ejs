<%- include('partials/header') %>

<main class="container">

<section class="page-header">

    <h1>
        Create Category
    </h1>

</section>

<% if (errors.length > 0) { %>

    <div class="error-list">

        <% errors.forEach(error => { %>

            <p><%= error %></p>

        <% }) %>

    </div>

<% } %>

<form
    action="/new-category"
    method="POST"
>

    <div class="form-group">

        <label for="name">
            Category Name
        </label>

        <input
            type="text"
            id="name"
            name="name"
            required
            maxlength="100"
            value="<%= category?.name || '' %>"
        >

    </div>

    <button type="submit">
        Create Category
    </button>

</form>

</main>

<%- include('partials/footer') %>
