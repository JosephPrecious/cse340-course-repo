<%- include('partials/header') %>

<main class="container">

    <section class="page-header">
        <h1><%= title %></h1>
        <p>
            Meet our trusted partner organizations making a difference
            through community service and volunteer opportunities.
        </p>

        <% if (
            user &&
            user.role_name === 'admin'
        ) { %>

            <div class="action-buttons">

                <a
                    href="/new-organization"
                    class="btn-primary"
                >
                    Add New Organization
                </a>

            </div>

        <% } %>
    </section>

    <section class="organizations-grid">

        <% organizations.forEach((organization) => { %>

            <article class="organization-card">

                <div class="organization-logo">
                    <img
                        src="/images/<%= organization.logo_filename %>"
                        alt="<%= organization.name %> logo"
                    >
                </div>

                <div class="organization-content">

                    <h2>
                        <a href="/organization/<%= organization.organization_id %>">
                            <%= organization.name %>
                        </a>
                    </h2>

                    <p class="organization-description">
                        <%= organization.description %>
                    </p>

                    <a
                        href="mailto:<%= organization.contact_email %>"
                        class="organization-email"
                    >
                        <%= organization.contact_email %>
                    </a>

                    <% if (
                        user &&
                        user.role_name === 'admin'
                    ) { %>

                        <div class="action-buttons">

                            <a
                                href="/edit-organization/<%= organization.organization_id %>"
                                class="btn-primary"
                            >
                                Edit
                            </a>

                        </div>

                    <% } %>

                </div>

            </article>

        <% }) %>

    </section>

</main>

<%- include('partials/footer') %>
