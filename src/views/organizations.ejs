<%- include('partials/header') %>

<main>

    <section class="page-header">
        <h1><%= title %></h1>
        <p>
            Meet the amazing organizations partnering with us to create
            impactful community service opportunities.
        </p>
    </section>

    <section class="card-grid">

        <article class="info-card">
            <img src="/images/brightfuture-logo.png" alt="BrightFuture Builders logo">

            <h2>BrightFuture Builders</h2>

            <p>
                Helping communities through housing and infrastructure projects.
            </p>

            <span>info@brightfuture.org</span>
        </article>

        <article class="info-card">
            <img src="/images/greenharvest-logo.png" alt="GreenHarvest Growers logo">

            <h2>GreenHarvest Growers</h2>

            <p>
                Promoting environmental sustainability and local agriculture.
            </p>

            <span>contact@greenharvest.org</span>
        </article>

        <article class="info-card">
            <img src="/images/unityserve-logo.png" alt="UnityServe Volunteers logo">

            <h2>UnityServe Volunteers</h2>

            <p>
                Connecting volunteers with outreach and humanitarian programs.
            </p>

            <span>hello@unityserve.org</span>
        </article>

    </section>

</main>

<%- include('partials/footer') %>