<%- include('partials/header') %>

<main class="container">

<section class="project-detail-card">

    <h1><%= project.name %></h1>

    <p class="project-description">
        <%= project.description %>
    </p>

    <div class="project-meta">

        <p>
            <strong>Date:</strong>
            <%= project.project_date %>
        </p>

        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>

        <p>
            <strong>Partner Organization:</strong>

            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

    </div>

    
    <div class="action-buttons">

        <a
            href="/edit-project/<%= project.project_id %>"
            class="btn-primary"
        >
            Edit Project
        </a>

        <a
            href="/project/<%= project.project_id %>/assign-categories"
            class="btn-primary"
        >
            Edit Categories
        </a>

    </div>

    <% if (user) { %>

        <div class="volunteer-section">

            <% if (!isVolunteer) { %>

                <form
                    action="/project/<%= project.project_id %>/volunteer"
                    method="POST"
                >

                    <button
                        type="submit"
                        class="btn-primary"
                    >
                        Volunteer For This Project
                    </button>

                </form>

            <% } else { %>

                <p class="volunteer-status">
                    You are volunteering for this project.
                </p>

                <form
                    action="/project/<%= project.project_id %>/remove-volunteer"
                    method="POST"
                >

                    <button
                        type="submit"
                        class="btn-danger"
                    >
                        Remove Volunteer Status
                    </button>

                </form>

            <% } %>

        </div>

    <% } %>

    <% if (categories.length > 0) { %>

        <h2>Categories</h2>

        <div class="tag-container">

            <% categories.forEach(category => { %>

                <a
                    href="/category/<%= category.category_id %>"
                    class="tag"
                >
                    <%= category.name %>
                </a>

            <% }) %>

        </div>

    <% } %>

</section>

</main>

<%- include('partials/footer') %>