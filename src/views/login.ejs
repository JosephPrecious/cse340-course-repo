<%- include('partials/header') %>

<main class="container">

    <section class="auth-container">

        <h1>Login</h1>

        <% if (errors && errors.length > 0) { %>

            <% errors.forEach(error => { %>
                <p class="error-message">
                    <%= error %>
                </p>
            <% }) %>

        <% } %>

        <form
            action="/login"
            method="POST"
        >

            <label for="email">
                Email
            </label>

            <input
                type="email"
                id="email"
                name="email"
                required
            >

            <label for="password">
                Password
            </label>

            <input
                type="password"
                id="password"
                name="password"
                required
            >

            <button
                type="submit"
                class="btn-primary"
            >
                Login
            </button>

        </form>

    </section>

</main>

<%- include('partials/footer') %>